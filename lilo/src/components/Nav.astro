---
import LiloLogo from "./LiloLogo.astro";

const links = [
  { href: "#mission", label: "Mission" },
  { href: "#vibe", label: "Vibe" },
  { href: "#countdown", label: "Countdown" },
  { href: "#mitmachen", label: "Mitmachen" },
];
---

<header class="nav">
  <div class="container nav__inner">
    <a class="nav__brand" href="#top" aria-label="LILO — zum Seitenanfang">
      <LiloLogo class="nav__logo" />
      <span class="nav__word">LILO<span class="nav__year">'26</span></span>
    </a>
    <nav class="nav__links" aria-label="Hauptnavigation">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
    <a class="nav__cta" href="#mitmachen">Save the Date</a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    border-bottom: 1px solid var(--line);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 64px;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink);
  }
  .nav__logo {
    width: 34px;
    height: 34px;
    color: var(--laser);
  }
  .nav__word {
    font-family: var(--font-display);
    font-size: 1.35rem;
    letter-spacing: 1px;
  }
  .nav__year {
    color: var(--majorelle);
  }
  .nav__links {
    display: none;
    margin-left: auto;
    gap: 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .nav__links a {
    color: var(--ink-dim);
    transition: color 0.2s ease;
  }
  .nav__links a:hover {
    color: var(--laser);
  }
  .nav__cta {
    margin-left: auto;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--laser);
    padding: 0.55rem 0.9rem;
    border-radius: 7px;
    white-space: nowrap;
  }
  @media (min-width: 880px) {
    .nav__links {
      display: flex;
    }
    .nav__cta {
      margin-left: 0;
    }
  }
</style>
