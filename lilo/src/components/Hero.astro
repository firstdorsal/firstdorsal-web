---
import ThermalCanvas from "./ThermalCanvas.tsx";
---

<section class="hero" id="top">
  <div class="hero__bg">
    <ThermalCanvas client:load />
  </div>
  <div class="hero__scrim"></div>

  <div class="container hero__inner">
    <p class="eyebrow" data-reveal>Route 01 — „laut“ · Underground</p>

    <h1 class="hero__title" data-reveal>
      <span class="hero__line">LAUT</span>
      <span class="hero__line hero__line--in">
        <span class="outline">IN</span>
        <span class="hero__star" aria-hidden="true">✦</span>
      </span>
      <span class="hero__line hero__line--love">LOVE</span>
    </h1>

    <div class="hero__meta" data-reveal>
      <span class="hero__date">28&thinsp;—&thinsp;31 · 08 · 2026</span>
      <span class="hero__dot">·</span>
      <span class="hero__tag">Wir sind laut.</span>
    </div>

    <p class="hero__lead" data-reveal>
      Das kollektive Herzklopfen eines Freundeskreises. Was als „Ja-Wort“ begann,
      wird zum gemeinsamen Rhythmus — bedingungslose Verbundenheit trifft auf die
      Energie einer durchtanzten Nacht.
    </p>

    <div class="hero__cta" data-reveal>
      <a class="btn btn--solid" href="#mitmachen">Save the Date</a>
      <a class="btn btn--ghost" href="#vibe">Der Vibe →</a>
    </div>
  </div>

  <div class="hero__scroll" aria-hidden="true">scroll ↓</div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    filter: saturate(1.15);
  }
  .hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse 70% 60% at 50% 40%, transparent, rgba(10, 10, 12, 0.55) 75%),
      linear-gradient(to bottom, rgba(10, 10, 12, 0.35), rgba(10, 10, 12, 0.9));
  }
  .hero__inner {
    z-index: 2;
    padding-block: 6rem 4rem;
  }
  .hero__title {
    margin-top: 1.4rem;
    font-size: clamp(4.2rem, 21vw, 15rem);
    text-shadow: 0 0 60px rgba(116, 45, 247, 0.35);
  }
  .hero__line {
    display: block;
  }
  .hero__line--in {
    display: flex;
    align-items: center;
    gap: clamp(0.6rem, 3vw, 2rem);
    color: var(--ink);
  }
  .hero__star {
    -webkit-text-stroke: 0;
    color: var(--laser);
    font-family: var(--font-mono);
    font-size: clamp(1.6rem, 6vw, 4rem);
    animation: spin 9s linear infinite;
  }
  .hero__line--love {
    color: var(--laser);
    text-shadow: 0 0 40px rgba(68, 247, 45, 0.45);
  }
  .hero__meta {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-mono);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-size: clamp(0.8rem, 2.6vw, 1rem);
  }
  .hero__date {
    color: var(--ink);
  }
  .hero__dot {
    color: var(--majorelle);
  }
  .hero__tag {
    color: var(--laser);
  }
  .hero__lead {
    margin-top: 1.6rem;
    max-width: 46ch;
    color: var(--ink-dim);
    font-size: clamp(0.95rem, 2.6vw, 1.1rem);
  }
  .hero__cta {
    margin-top: 2.2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }
  .hero__scroll {
    position: absolute;
    bottom: 1.1rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ink-dim);
    animation: bob 2.4s ease-in-out infinite;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.95rem 1.5rem;
    border-radius: 8px;
    transition: transform 0.05s ease, filter 0.2s ease, background 0.2s ease;
  }
  .btn:active {
    transform: translateY(1px);
  }
  .btn--solid {
    background: var(--laser);
    color: #06120a;
  }
  .btn--solid:hover {
    filter: brightness(1.1);
  }
  .btn--ghost {
    border: 1px solid var(--majorelle);
    color: var(--ink);
  }
  .btn--ghost:hover {
    background: rgba(116, 45, 247, 0.18);
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }
  @keyframes bob {
    50% {
      transform: translate(-50%, 6px);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__star,
    .hero__scroll {
      animation: none;
    }
  }
</style>
