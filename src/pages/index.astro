---
import Layout from '../layouts/Layout.astro'
import SiteHeader from '@/components/SiteHeader.astro'
import SiteFooter from '@/components/SiteFooter.astro'
import { Hero } from '@/components/Hero'
import { Leistungen } from '@/components/Leistungen'
import { Vorgehen } from '@/components/Vorgehen'
import { Referenzen } from '@/components/Referenzen'
import { Kontakt } from '@/components/Kontakt'

// Strukturierte Daten für die lokale Suche (Google: "IT-Dienstleister
// Augsburg" etc.). Schema.org ProfessionalService mit Anschrift.
const strukturierteDaten = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'firstdorsal IT-Dienstleistungen',
  url: 'https://firstdorsal.eu/',
  image: 'https://firstdorsal.eu/og.png',
  email: 'mail@firstdorsal.eu',
  description:
    'Softwareentwicklung und kreatives Webdesign, IT-Forensik mit technischen Gutachten sowie Betrieb & Infrastruktur – aus Augsburg.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Imhofstraße 12',
    postalCode: '86159',
    addressLocality: 'Augsburg',
    addressCountry: 'DE',
  },
}
---

<Layout lang="de" alternates={{ de: '/', en: '/en/' }}>
  <div class="min-h-svh bg-background text-foreground">
    <SiteHeader lang="de" />

    <main>
      <Hero lang="de" />
      <Leistungen lang="de" />
      <Vorgehen lang="de" />
      <Referenzen lang="de" />
      <Kontakt lang="de" client:load />
    </main>

    <SiteFooter lang="de" />
  </div>

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(strukturierteDaten)}
  />
</Layout>
