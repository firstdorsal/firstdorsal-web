---
import Layout from '../../layouts/Layout.astro'
import SiteHeader from '@/components/SiteHeader.astro'
import SiteFooter from '@/components/SiteFooter.astro'
import { Hero } from '@/components/Hero'
import { Leistungen } from '@/components/Leistungen'
import { Vorgehen } from '@/components/Vorgehen'
import { Kontakt } from '@/components/Kontakt'

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'firstdorsal IT-Dienstleistungen',
  url: 'https://firstdorsal.eu/en/',
  image: 'https://firstdorsal.eu/og.png',
  email: 'mail@firstdorsal.eu',
  description:
    'Software development and creative web design, IT forensics with technical expert reports, plus operations & infrastructure – based in Augsburg, Germany.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Imhofstraße 12',
    postalCode: '86159',
    addressLocality: 'Augsburg',
    addressCountry: 'DE',
  },
}
---

<Layout
  lang="en"
  title="firstdorsal · IT services"
  description="firstdorsal IT services, Augsburg (Germany) – software development and creative web design, IT forensics with technical expert reports, plus operations & infrastructure."
  alternates={{ de: '/', en: '/en/' }}
>
  <div class="min-h-svh bg-background text-foreground">
    <SiteHeader lang="en" />

    <main>
      <Hero lang="en" />
      <Leistungen lang="en" />
      <Vorgehen lang="en" />
      <Kontakt lang="en" client:load />
    </main>

    <SiteFooter lang="en" />
  </div>

  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(structuredData)}
  />
</Layout>
