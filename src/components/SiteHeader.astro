---
import { ModeToggle } from '@/components/ModeToggle'
import { SpineMark } from '@/components/SpineMark'
---

<header
  class="sticky top-0 z-40 border-b border-border/70 bg-background/85 backdrop-blur-sm"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3"
  >
    <a
      href="/"
      class="flex items-center gap-2.5"
      aria-label="firstdorsal – zur Startseite"
    >
      <SpineMark className="h-6 w-6 text-sienna" />
      <span class="font-serif text-xl font-semibold tracking-tight"
        >firstdorsal</span
      >
    </a>
    <nav
      class="label-caps hidden items-center gap-8 text-muted-foreground sm:flex"
      aria-label="Hauptnavigation"
    >
      <a class="transition-colors hover:text-foreground" href="/#leistungen"
        >Leistungen</a
      >
      <a class="transition-colors hover:text-foreground" href="/#vorgehen"
        >Vorgehen</a
      >
      <a class="transition-colors hover:text-foreground" href="/#kontakt"
        >Kontakt</a
      >
    </nav>
    <ModeToggle client:load />
  </div>
</header>
