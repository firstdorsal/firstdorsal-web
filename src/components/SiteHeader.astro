---
import { ModeToggle } from '@/components/ModeToggle'
import { SpineMark } from '@/components/SpineMark'
---

<header
  class="sticky top-0 z-40 border-b border-border/70 bg-background/85 backdrop-blur-sm"
>
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3"
  >
    <a
      href="/"
      class="flex items-center gap-2.5"
      aria-label="firstdorsal IT-Dienstleistungen – zur Startseite"
    >
      <SpineMark className="h-6 w-6 text-brand" />
      <span class="font-serif text-xl font-semibold tracking-tight"
        >firstdorsal</span
      >
    </a>
    <ModeToggle client:load />
  </div>
</header>
