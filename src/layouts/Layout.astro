---
// Schriften lokal einbinden – kein CDN. Fraunces „standard" enthält die
// opsz-Achse (optische Größen für Display-Schnitte), dazu die Kursive für
// Anmerkungen im Tafel-Stil. Hack kommt per @font-face in global.css.
import '@fontsource-variable/fraunces/standard.css'
import '@fontsource-variable/fraunces/standard-italic.css'
import '@fontsource-variable/libre-franklin'
import '../styles/global.css'

import type { Lang } from '@/lib/i18n'

interface Props {
  title?: string
  description?: string
  lang?: Lang
  // Pfade der Sprachvarianten dieser Seite; wenn gesetzt, werden
  // hreflang-Alternates gerendert (nur für Seiten, die es in beiden
  // Sprachen gibt).
  alternates?: { de: string; en: string }
  // Seite aus Suchmaschinen heraushalten (z. B. Chat-Verwaltung).
  noindex?: boolean
}

const {
  title = 'firstdorsal · IT-Dienstleistungen',
  description = 'firstdorsal IT-Dienstleistungen, Augsburg – Softwareentwicklung und kreatives Webdesign, IT-Forensik mit technischen Gutachten sowie Betrieb & Infrastruktur.',
  lang = 'de',
  alternates,
  noindex = false,
} = Astro.props

// Absolute URLs für Canonical und Social-Media-Vorschauen (Discord, Signal
// & Co. brauchen ein absolutes og:image).
const canonical = new URL(Astro.url.pathname, Astro.site)
const ogImage = new URL('/og.png', Astro.site)
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    {
      alternates && (
        <>
          <link
            rel="alternate"
            hreflang="de"
            href={new URL(alternates.de, Astro.site)}
          />
          <link
            rel="alternate"
            hreflang="en"
            href={new URL(alternates.en, Astro.site)}
          />
          <link
            rel="alternate"
            hreflang="x-default"
            href={new URL(alternates.de, Astro.site)}
          />
        </>
      )
    }
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <!-- Die Seite bringt ihren eigenen Dark Mode mit – Dark Reader soll
         nicht zusätzlich umfärben. -->
    <meta name="darkreader-lock" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="firstdorsal IT-Dienstleistungen" />
    <meta property="og:locale" content={lang === 'de' ? 'de_DE' : 'en_US'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="firstdorsal – Das Rückgrat Ihrer IT." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
    <!-- Theme vor dem ersten Paint setzen (verhindert Flackern); html.js
         schaltet die Scroll-Einblendungen frei (Fallback ohne JS: alles
         sichtbar). -->
    <script is:inline>
      document.documentElement.classList.add('js')
      const stored = localStorage.getItem('fd-theme')
      const dark =
        stored === 'dark' ||
        (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)
      document.documentElement.classList.toggle('dark', dark)
    </script>
  </head>
  <body>
    <!-- Papierkorn + Vignette der anatomischen Tafel, klicktransparent. -->
    <div class="texture-overlay" aria-hidden="true"></div>
    <slot />
    <script>
      // Scroll-Einblendungen für .reveal-Elemente. Bei reduzierter Bewegung
      // sofort sichtbar (CSS deckt das zusätzlich ab).
      const els = document.querySelectorAll<HTMLElement>('.reveal')
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        els.forEach((el) => el.classList.add('is-visible'))
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible')
                io.unobserve(entry.target)
              }
            }
          },
          { threshold: 0.15 },
        )
        els.forEach((el) => io.observe(el))
      }
    </script>
  </body>
</html>
