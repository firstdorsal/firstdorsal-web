# Vorlage für deployment/provided-secrets.env – die echte Datei liegt nur
# auf dem Server (gitignored) und wird vom Compose-Template als env_file
# eingebunden.

# SMTP-Versand der Magic-Link-Mails (vorhandener Account, TLS).
SMTP_HOST=mail.example.org
SMTP_PORT=465
# implicit (Port 465, Standard) oder starttls (Port 587)
SMTP_TLS=implicit
SMTP_USER=mail@firstdorsal.eu
SMTP_PASSWORD=geheim
MAIL_FROM=firstdorsal <mail@firstdorsal.eu>

# Wer sich mit diesen Adressen anmeldet, bekommt Operator-Zugang zur
# Chat-Verwaltung (/chat/admin/). Mehrere Adressen mit Komma trennen.
OPERATOR_EMAILS=mail@firstdorsal.eu

# Optional: Transkriptionssprache erzwingen (z. B. de). Standard:
# Autodetect – mit large-v3-turbo zuverlässig, nur kleine Modelle
# brauchen die Hilfe.
#WHISPER_LANGUAGE=de
