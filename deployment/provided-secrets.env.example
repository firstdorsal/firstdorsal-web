# Vorlage für deployment/provided-secrets.env – die echte Datei liegt nur
# auf dem Server (gitignored) und wird vom Compose-Template als env_file
# eingebunden.

# SMTP-Versand der Magic-Link-Mails (vorhandener Account, TLS).
SMTP_HOST=mail.example.org
SMTP_PORT=465
# implicit (Port 465, Standard) oder starttls (Port 587)
SMTP_TLS=implicit
SMTP_USER=mail@firstdorsal.eu
SMTP_PASSWORD=geheim
MAIL_FROM=firstdorsal <mail@firstdorsal.eu>

# Wer sich mit diesen Adressen anmeldet, bekommt Operator-Zugang zur
# Chat-Verwaltung (/chat/admin/). Mehrere Adressen mit Komma trennen.
OPERATOR_EMAILS=mail@firstdorsal.eu

# Optional: Transkriptionssprache erzwingen (z. B. de). Standard:
# Autodetect – mit large-v3-turbo zuverlässig, nur kleine Modelle
# brauchen die Hilfe.
#WHISPER_LANGUAGE=de

# --- WebRTC-Anrufe (Sprache/Video/Screensharing) -----------------------
# Ohne diese Werte funktionieren Anrufe direkt bzw. über STUN (die meisten
# Netze). Für strenge NATs/Firewalls den coturn-Dienst aktivieren:
# TURN_SECRET setzen (= --static-auth-secret von coturn) und die TURN-/STUN-
# URLs an den Server-Hostnamen anpassen. Der Rust-Dienst liefert daraus die
# zeitlich begrenzten ICE-Zugangsdaten an die Clients.
#TURN_SECRET=langes-zufaelliges-geheimnis
#STUN_URLS=stun:firstdorsal.eu:3478
#TURN_URLS=turn:firstdorsal.eu:3478?transport=udp,turn:firstdorsal.eu:3478?transport=tcp
# Nur falls der Server hinter NAT steht (Cloud): seine öffentliche IP.
#TURN_EXTERNAL_IP=203.0.113.10
# Gültigkeitsdauer der TURN-Zugangsdaten in Sekunden (Standard 3600).
#TURN_TTL=3600
